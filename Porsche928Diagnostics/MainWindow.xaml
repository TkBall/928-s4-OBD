<Window x:Class="Porsche928Diagnostics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Porsche928Diagnostics.Views"
        xmlns:theme="clr-namespace:Porsche928Diagnostics.Theme"
        Title="Porsche 928 K-Line Diagnostic Tool"
        Height="780" Width="1320"
        Background="{DynamicResource Bg.Page}"
        Foreground="{DynamicResource Text.Primary}"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13">

    <DockPanel>

        <!-- ── Command bar ── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Bg.Card}"
                BorderBrush="{DynamicResource Border.Default}"
                BorderThickness="0,0,0,1"
                Height="52">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PORT"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text.Muted}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding AvailablePorts}"
                              SelectedItem="{Binding SelectedPort}"
                              Width="100"
                              IsEnabled="{Binding IsDisconnected}"/>
                    <Button Content="Refresh"
                            Command="{Binding RefreshPortsCommand}"
                            MinWidth="70" Margin="6,0,0,0"/>
                    <Button Content="Connect"
                            Command="{Binding ConnectAsyncCommand}"
                            Style="{StaticResource Btn.Primary}"
                            MinWidth="88" Margin="6,0,0,0"/>
                    <Button Content="Disconnect"
                            Command="{Binding DisconnectCommand}"
                            Style="{StaticResource Btn.Danger}"
                            MinWidth="100" Margin="6,0,0,0"/>

                    <Border Width="1" Background="{DynamicResource Border.Default}" Margin="16,10"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource StatusText}"
                               VerticalAlignment="Center"
                               MaxWidth="480"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{Binding HasError, Converter={x:Static views:BoolToColorConverter.Instance}}"/>

                    <ProgressBar IsIndeterminate="True"
                                 Width="80" Height="3"
                                 Margin="12,0,0,0"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}"/>
                </StackPanel>

                <!-- Light / Dark / Auto theme toggle -->
                <Border Grid.Column="1"
                        Background="{DynamicResource Bg.CardRaised}"
                        BorderBrush="{DynamicResource Border.Default}"
                        BorderThickness="1"
                        CornerRadius="6"
                        VerticalAlignment="Center"
                        Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton Content="Light" Style="{StaticResource Btn.ThemeSegment}"
                                      Command="{Binding SetThemeCommand}"
                                      CommandParameter="{x:Static theme:AppTheme.Light}"
                                      IsChecked="{Binding CurrentTheme, Converter={x:Static views:EnumEqualsConverter.Instance}, ConverterParameter={x:Static theme:AppTheme.Light}, Mode=OneWay}"/>
                        <ToggleButton Content="Dark" Style="{StaticResource Btn.ThemeSegment}"
                                      Command="{Binding SetThemeCommand}"
                                      CommandParameter="{x:Static theme:AppTheme.Dark}"
                                      IsChecked="{Binding CurrentTheme, Converter={x:Static views:EnumEqualsConverter.Instance}, ConverterParameter={x:Static theme:AppTheme.Dark}, Mode=OneWay}"/>
                        <ToggleButton Content="Auto" Style="{StaticResource Btn.ThemeSegment}"
                                      Command="{Binding SetThemeCommand}"
                                      CommandParameter="{x:Static theme:AppTheme.Auto}"
                                      IsChecked="{Binding CurrentTheme, Converter={x:Static views:EnumEqualsConverter.Instance}, ConverterParameter={x:Static theme:AppTheme.Auto}, Mode=OneWay}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Module navigation (Fluent NavigationView-style left rail) ── -->
        <TabControl TabStripPlacement="Left">

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center"
                                 Fill="{Binding DataContext.Lh.IsSessionActive,
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        Converter={x:Static views:SessionDotConverter.Instance}}"/>
                        <TextBlock Text="LH Injection"/>
                    </StackPanel>
                </TabItem.Header>
                <views:LhView DataContext="{Binding Lh}"/>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center"
                                 Fill="{Binding DataContext.Ezk.IsSessionActive,
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        Converter={x:Static views:SessionDotConverter.Instance}}"/>
                        <TextBlock Text="EZK Ignition"/>
                    </StackPanel>
                </TabItem.Header>
                <views:EzkView DataContext="{Binding Ezk}"/>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center"
                                 Fill="{Binding DataContext.Psd.IsSessionActive,
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        Converter={x:Static views:SessionDotConverter.Instance}}"/>
                        <TextBlock Text="PSD Differential"/>
                    </StackPanel>
                </TabItem.Header>
                <views:PsdView DataContext="{Binding Psd}"/>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center"
                                 Fill="{Binding DataContext.Rdk.IsSessionActive,
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        Converter={x:Static views:SessionDotConverter.Instance}}"/>
                        <TextBlock Text="RDK Tyres"/>
                    </StackPanel>
                </TabItem.Header>
                <views:RdkView DataContext="{Binding Rdk}"/>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center"
                                 Fill="{Binding DataContext.Airbag.IsSessionActive,
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        Converter={x:Static views:SessionDotConverter.Instance}}"/>
                        <TextBlock Text="Airbag"/>
                    </StackPanel>
                </TabItem.Header>
                <views:AirbagView DataContext="{Binding Airbag}"/>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center"
                                 Fill="{Binding DataContext.Alarm.IsSessionActive,
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        Converter={x:Static views:SessionDotConverter.Instance}}"/>
                        <TextBlock Text="Alarm"/>
                    </StackPanel>
                </TabItem.Header>
                <views:AlarmView DataContext="{Binding Alarm}"/>
            </TabItem>

            <TabItem Header="Digital Dash">
                <views:DigitalDashView DataContext="{Binding DigitalDash}"/>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
