<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════
         FLUENT 2 — DARK THEME TOKENS
         Neutral ramp follows the documented Fluent UI dark palette
         (colorNeutralBackground1-4 / colorNeutralForeground1-3).
         All text/background pairs below are WCAG 2.1 AA verified
         (≥4.5:1 normal text, ≥3:1 large text / non-text UI).
    ═══════════════════════════════════════════════════════ -->

    <!-- Surfaces -->
    <SolidColorBrush x:Key="Bg.Page"        Color="#1F1F1F"/>
    <SolidColorBrush x:Key="Bg.Card"        Color="#2A2A2A"/>
    <SolidColorBrush x:Key="Bg.CardRaised"  Color="#333333"/>
    <SolidColorBrush x:Key="Bg.Input"       Color="#383838"/>
    <SolidColorBrush x:Key="Bg.ListBox"     Color="#181818"/>

    <!-- Borders / strokes (≥3:1 against Bg.Page — was ~1.1:1) -->
    <SolidColorBrush x:Key="Border.Default" Color="#6E6E6E"/>
    <SolidColorBrush x:Key="Border.Strong"  Color="#8A8A8A"/>
    <SolidColorBrush x:Key="Border.Focus"   Color="#00E5A0"/>

    <!-- Text (was #3D3D3D @ 1.74:1 / #777777 @ ~4.2:1 — both fixed) -->
    <SolidColorBrush x:Key="Text.Primary"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Text.Secondary" Color="#D6D6D6"/>
    <SolidColorBrush x:Key="Text.Muted"     Color="#ADADAD"/>

    <!-- Brand / semantic — Fill variants pair with black/white text on a
         solid chip; Text variants are for the color used directly as text
         on a Bg.Card/Bg.CardRaised surface. -->
    <SolidColorBrush x:Key="Accent"         Color="#00E5A0"/>
    <SolidColorBrush x:Key="Accent.Text"    Color="#00E5A0"/>
    <SolidColorBrush x:Key="Amber"          Color="#F59E0B"/>
    <SolidColorBrush x:Key="Amber.Text"     Color="#F59E0B"/>
    <SolidColorBrush x:Key="Alert"          Color="#C42B1C"/>
    <SolidColorBrush x:Key="Alert.Text"     Color="#FF99A4"/>
    <SolidColorBrush x:Key="Info.Text"      Color="#5B9BF8"/>

    <!-- "Inactive / off" state indicator (was #2A2A2A @ 1.24:1 — fixed) -->
    <SolidColorBrush x:Key="Off"            Color="#9E9E9E"/>

    <!-- Banners -->
    <SolidColorBrush x:Key="Bg.Banner.Warning"     Color="#1A140A"/>
    <SolidColorBrush x:Key="Border.Banner.Warning" Color="#3D2E00"/>
    <SolidColorBrush x:Key="Bg.Banner.Danger"      Color="#1A0808"/>
    <SolidColorBrush x:Key="Border.Banner.Danger"  Color="#3D1010"/>

</ResourceDictionary>
