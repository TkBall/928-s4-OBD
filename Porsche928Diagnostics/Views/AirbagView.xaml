<UserControl x:Class="Porsche928Diagnostics.Views.AirbagView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Porsche928Diagnostics.Views"
             Background="#090909" Foreground="#EEEEEE">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="{Binding IsSessionActive, Converter={x:Static views:SessionDotConverter.Instance}}"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,8">
            <StackPanel>

                <!-- ECU SESSION -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="ECU SESSION" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource AlertBanner}">
                            <TextBlock Foreground="#F59E0B" FontSize="12" TextWrapping="Wrap"
                                       Text="ℹ MODEL YEAR NOTE — Airbags were not fitted to any 928 before MY1990; a pre-1990 car will have no airbag ECU to query at all. From MY1990, UK/RHD cars (like F57GNT) received a driver-side airbag only — no passenger airbag was ever fitted to RHD cars due to dashboard packaging, so the passenger field below will read empty/false by design."/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Initialise Airbag Session" Command="{Binding ConnectEcuAsyncCommand}"
                                    Style="{StaticResource Btn.Primary}"/>
                            <TextBlock Text="{Binding EcuId}" Style="{StaticResource EcuIdText}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Read Fault Codes"  Command="{Binding ReadDtcsAsyncCommand}"/>
                            <Button Content="Clear Fault Codes" Command="{Binding ClearDtcsAsyncCommand}"
                                    Style="{StaticResource Btn.Danger}"/>
                            <Button Content="Copy"              Command="{Binding CopyDtcsCommand}"
                                    Style="{StaticResource Btn.Small}"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Dtcs}" MaxHeight="130">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}" FontFamily="Consolas" FontSize="12"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- AIRBAG STATUS -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="AIRBAG STATUS" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource DangerBanner}">
                            <TextBlock Foreground="#EF9090" FontSize="12" TextWrapping="Wrap"
                                       Text="⚠  Do not work on the airbag circuit until the capacitor discharge time shown below has elapsed (typically 15–30 minutes after battery disconnect)."/>
                        </Border>
                        <Button Content="Read Airbag Data" Command="{Binding ReadAirbagDataAsyncCommand}"
                                Style="{StaticResource Btn.Primary}" HorizontalAlignment="Left" Margin="0,0,0,14"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource ValueTile}" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="CAPACITOR DOWNTIME" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding DowntimeClock}"
                                               Style="{StaticResource ValueDisplay}" Foreground="#3B82F6"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="CRASH EVENT RECORDED" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding CrashEventRecorded}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding CrashEventRecorded, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <TextBlock Text="DEPLOYMENT STATUS" Style="{StaticResource SectionHeader}"/>
                        <UniformGrid Columns="3">
                            <Border Margin="0,0,6,0" Padding="14,12" CornerRadius="8" BorderThickness="1.5"
                                    BorderBrush="{Binding DriverBagFired, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="DRIVER AIRBAG" Style="{StaticResource ValueLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DriverBagFired}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding DriverBagFired, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,6,0" Padding="14,12" CornerRadius="8" BorderThickness="1.5"
                                    BorderBrush="{Binding PassengerBagFired, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="PASSENGER AIRBAG (not fitted — RHD)" Style="{StaticResource ValueLabel}"
                                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding PassengerBagFired}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding PassengerBagFired, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="14,12" CornerRadius="8" BorderThickness="1.5"
                                    BorderBrush="{Binding SeatbeltFired, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="SEATBELT PRETENSIONER" Style="{StaticResource ValueLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SeatbeltFired}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding SeatbeltFired, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource StatusBar}" Margin="20,0,20,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusText}"
                       Foreground="{Binding HasError, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
        </Border>
    </Grid>
</UserControl>
