<UserControl x:Class="Porsche928Diagnostics.Views.AlarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Porsche928Diagnostics.Views"
             Background="#090909" Foreground="#EEEEEE">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="{Binding IsSessionActive, Converter={x:Static views:SessionDotConverter.Instance}}"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
            <StackPanel>

                <!-- ECU SESSION -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="ECU SESSION" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Initialise Alarm Session" Command="{Binding ConnectEcuAsyncCommand}"
                                    Style="{StaticResource Btn.Primary}"/>
                            <TextBlock Text="{Binding EcuId}" Style="{StaticResource EcuIdText}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Read Fault Codes"  Command="{Binding ReadDtcsAsyncCommand}"/>
                            <Button Content="Clear Fault Codes" Command="{Binding ClearDtcsAsyncCommand}"
                                    Style="{StaticResource Btn.Danger}"/>
                            <Button Content="Copy"              Command="{Binding CopyDtcsCommand}"
                                    Style="{StaticResource Btn.Small}"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Dtcs}" MaxHeight="130">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}" FontFamily="Consolas" FontSize="12"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- PERIMETER SWITCHES -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="PERIMETER SWITCHES" Style="{StaticResource SectionHeader}"/>
                        <Button Content="Read Input Signals" Command="{Binding ReadAlarmDataAsyncCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,14"/>
                        <UniformGrid Columns="2">
                            <Border Margin="0,0,6,6" Padding="14,12" CornerRadius="8" BorderThickness="1.5"
                                    BorderBrush="{Binding EngineLidOpen, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel>
                                    <TextBlock Text="ENGINE LID" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding EngineLidOpen}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding EngineLidOpen, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,0,6" Padding="14,12" CornerRadius="8" BorderThickness="1.5"
                                    BorderBrush="{Binding LuggageLidOpen, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel>
                                    <TextBlock Text="LUGGAGE LID" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding LuggageLidOpen}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding LuggageLidOpen, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,6,0" Padding="14,12" CornerRadius="8" BorderThickness="1.5"
                                    BorderBrush="{Binding GloveBoxOpen, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel>
                                    <TextBlock Text="GLOVE BOX" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding GloveBoxOpen}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding GloveBoxOpen, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="14,12" CornerRadius="8" BorderThickness="1.5"
                                    BorderBrush="{Binding MotionSensorActive, Converter={x:Static views:BoolToColorConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel>
                                    <TextBlock Text="INTERIOR MOTION" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding MotionSensorActive}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding MotionSensorActive, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- COUNTRY CODING -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="COUNTRY CODING" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="CURRENT:" Style="{StaticResource ValueLabel}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding CountryCode}"
                                       FontFamily="Bahnschrift, Segoe UI" FontSize="22"
                                       Foreground="#00E5A0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox ItemsSource="{Binding CountryCodeOptions}"
                                      SelectedItem="{Binding SelectedCountryCode}"
                                      Width="90"/>
                            <Button Content="Write Country Code" Command="{Binding SetCountryCodingAsyncCommand}"
                                    Style="{StaticResource Btn.Primary}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- DRIVE LINK TESTS -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="DRIVE LINK TESTS" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Test Horn (2s)"        Command="{Binding ActivateHornAsyncCommand}"      Style="{StaticResource Btn.Amber}"/>
                            <Button Content="Flash Indicators (3s)" Command="{Binding FlashIndicatorsAsyncCommand}"   Style="{StaticResource Btn.Amber}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- STATUS -->
                <Border Style="{StaticResource StatusBar}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource StatusText}"
                               Foreground="{Binding HasError, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
