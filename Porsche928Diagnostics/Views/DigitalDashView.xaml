<UserControl x:Class="Porsche928Diagnostics.Views.DigitalDashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Porsche928Diagnostics.Views"
             Background="#090909" Foreground="#EEEEEE">
    <DockPanel>
        <!-- STATUS — pinned to bottom, always visible -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource StatusBar}" Margin="20,0,20,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusText}"
                       Foreground="{Binding HasError, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,8">
        <StackPanel>

            <!-- HEADER -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="DIGITAL INSTRUMENT CLUSTER"
                           FontFamily="Bahnschrift, Segoe UI" FontSize="20"
                           Foreground="#EEEEEE" Margin="0,0,0,4"/>
                <TextBlock Foreground="#777777" FontSize="12" TextWrapping="Wrap"
                           Text="Self-test mode activated by grounding Pin 6 of the 19-pin connector (passenger footwell). No K-Line communication — guided operator procedure only."/>
            </StackPanel>

            <!-- GUIDED SEQUENCE -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="GUIDED SEQUENCE" Style="{StaticResource SectionHeader}"/>
                    <ProgressBar Value="{Binding CurrentStep}" Maximum="{Binding TotalSteps}"
                                 Margin="0,0,0,14" Height="3"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding CurrentStep, StringFormat=Step {0}}"
                                   FontFamily="Bahnschrift, Segoe UI" FontSize="24" Foreground="#00E5A0"/>
                        <TextBlock Text="{Binding TotalSteps, StringFormat= / {0}}"
                                   FontFamily="Bahnschrift, Segoe UI" FontSize="24" Foreground="#3D3D3D"/>
                    </StackPanel>
                    <Border Style="{StaticResource ValueTile}" Margin="0,0,0,14">
                        <TextBlock Text="{Binding CurrentInstruction}"
                                   FontSize="14" Foreground="#EEEEEE"
                                   TextWrapping="Wrap" LineHeight="22"/>
                    </Border>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="▶ Start Guided Sequence" Command="{Binding StartSequenceAsyncCommand}"
                                Style="{StaticResource Btn.Primary}" MinWidth="190" Height="46"/>
                        <Button Content="■ Stop" Command="{Binding StopSequenceCommand}"
                                MinWidth="80" Height="46"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- READINGS CHECKLIST -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="READINGS CHECKLIST" Style="{StaticResource SectionHeader}" Margin="0"/>
                        <Button Grid.Column="1" Content="Reset" Command="{Binding ResetChecklistCommand}"
                                Style="{StaticResource Btn.Small}"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Checklist}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="14,12" CornerRadius="8" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"  Value="#181818"/>
                                            <Setter Property="BorderBrush" Value="#222222"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                    <Setter Property="Background"  Value="#1A0E08"/>
                                                    <Setter Property="BorderBrush" Value="#3D2010"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Text}"
                                                   FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#EEEEEE"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsChecked}"
                                                  VerticalAlignment="Center" Margin="16,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
