<UserControl x:Class="Porsche928Diagnostics.Views.EzkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Porsche928Diagnostics.Views"
             Background="#090909" Foreground="#EEEEEE">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="{Binding IsSessionActive, Converter={x:Static views:SessionDotConverter.Instance}}"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,8">
            <StackPanel>

                <!-- ECU SESSION -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="ECU SESSION" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Initialise EZK Session" Command="{Binding ConnectEcuAsyncCommand}"
                                    Style="{StaticResource Btn.Primary}"/>
                            <TextBlock Text="{Binding EcuId}" Style="{StaticResource EcuIdText}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Read Fault Codes"  Command="{Binding ReadDtcsAsyncCommand}"/>
                            <Button Content="Clear Fault Codes" Command="{Binding ClearDtcsAsyncCommand}"
                                    Style="{StaticResource Btn.Danger}"/>
                            <Button Content="Copy"              Command="{Binding CopyDtcsCommand}"
                                    Style="{StaticResource Btn.Small}"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Dtcs}" MaxHeight="130">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}" FontFamily="Consolas" FontSize="12"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- ENGINE TELEMETRY -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="ENGINE TELEMETRY" Style="{StaticResource SectionHeader}"/>
                        <Button Content="Read Sensor Data" Command="{Binding ReadSensorDataAsyncCommand}"
                                Style="{StaticResource Btn.Primary}" HorizontalAlignment="Left" Margin="0,0,0,14"/>
                        <UniformGrid Columns="2">
                            <Border Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="ENGINE RPM" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding EngineRpm, StringFormat={}{0} RPM}"
                                               Style="{StaticResource ValueDisplay}" Foreground="#00E5A0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="ENGINE LOAD" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding LoadPercent, StringFormat={}{0:F1}%}"
                                               Style="{StaticResource ValueDisplay}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="ENGINE TEMP" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding EngineTemperature, StringFormat={}{0:F0} °C}"
                                               Style="{StaticResource ValueDisplay}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="TRANSMISSION" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding TransmissionCoding}"
                                               Style="{StaticResource ValueDisplay}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- KNOCK REGISTRATION -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="KNOCK REGISTRATION" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource AlertBanner}">
                            <TextBlock Foreground="#F59E0B" FontSize="12" TextWrapping="Wrap"
                                       Text="Non-zero values indicate active timing retardation on that cylinder. Values above 10 warrant investigation."/>
                        </Border>
                        <Button Content="Read Knock Counts" Command="{Binding ReadKnockCountsAsyncCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,10"/>
                        <ListBox ItemsSource="{Binding KnockCounts}" MaxHeight="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}" FontFamily="Consolas" FontSize="12"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource StatusBar}" Margin="20,0,20,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusText}"
                       Foreground="{Binding HasError, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
        </Border>
    </Grid>
</UserControl>
