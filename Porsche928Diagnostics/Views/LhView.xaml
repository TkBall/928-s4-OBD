<UserControl x:Class="Porsche928Diagnostics.Views.LhView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Porsche928Diagnostics.Views"
             Background="#090909" Foreground="#EEEEEE">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="{Binding IsSessionActive, Converter={x:Static views:SessionDotConverter.Instance}}"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
            <StackPanel>

                <!-- ECU SESSION -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="ECU SESSION" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Initialise LH Session" Command="{Binding ConnectEcuAsyncCommand}"
                                    Style="{StaticResource Btn.Primary}"/>
                            <TextBlock Text="{Binding EcuId}" Style="{StaticResource EcuIdText}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Read Fault Codes"  Command="{Binding ReadDtcsAsyncCommand}"/>
                            <Button Content="Clear Fault Codes" Command="{Binding ClearDtcsAsyncCommand}"
                                    Style="{StaticResource Btn.Danger}"/>
                            <Button Content="Copy"              Command="{Binding CopyDtcsCommand}"
                                    Style="{StaticResource Btn.Small}"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Dtcs}" MaxHeight="130">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}" FontFamily="Consolas" FontSize="12"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- SENSOR VALUES -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="SENSOR VALUES" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Button Content="Read Static Values"              Command="{Binding ReadActualValuesAsyncCommand}"/>
                            <Button Content="Read Active Values (Engine On)"  Command="{Binding ReadActiveValuesAsyncCommand}"/>
                        </StackPanel>
                        <UniformGrid Columns="3">
                            <Border Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="BATTERY VOLTAGE" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding BatteryVoltage, StringFormat={}{0:F2} V}"
                                               Style="{StaticResource ValueDisplay}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="ENGINE TEMP" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding EngineTemperature, StringFormat={}{0:F0} °C}"
                                               Style="{StaticResource ValueDisplay}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="MAF VOLTAGE" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding MafVoltage, StringFormat={}{0:F2} V}"
                                               Style="{StaticResource ValueDisplay}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="LAMBDA (O₂)" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding LambdaVoltage, StringFormat={}{0:F0} mV}"
                                               Style="{StaticResource ValueDisplay}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ValueTile}">
                                <StackPanel>
                                    <TextBlock Text="EZK ON SIGNAL" Style="{StaticResource ValueLabel}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Fill="{Binding EzkOnSignal, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"/>
                                        <TextBlock Text="{Binding EzkOnSignal}"
                                                   Style="{StaticResource ValueDisplaySmall}"
                                                   Foreground="{Binding EzkOnSignal, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- INPUT SIGNALS -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="INPUT SIGNALS" Style="{StaticResource SectionHeader}"/>
                        <Button Content="Read Input Signals" Command="{Binding ReadInputSignalsAsyncCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,14"/>
                        <UniformGrid Columns="3">
                            <Border Margin="0,0,6,0" Padding="14,12" CornerRadius="8" BorderThickness="1"
                                    BorderBrush="{Binding ThrottleIdleSwitch, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel>
                                    <TextBlock Text="THROTTLE IDLE" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding ThrottleIdleSwitch}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding ThrottleIdleSwitch, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,6,0" Padding="14,12" CornerRadius="8" BorderThickness="1"
                                    BorderBrush="{Binding WotSwitch, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel>
                                    <TextBlock Text="WIDE OPEN THROTTLE" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding WotSwitch}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding WotSwitch, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="14,12" CornerRadius="8" BorderThickness="1"
                                    BorderBrush="{Binding AircoActive, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel>
                                    <TextBlock Text="A/C DEMAND" Style="{StaticResource ValueLabel}"/>
                                    <TextBlock Text="{Binding AircoActive}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding AircoActive, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- DRIVE LINK TESTS -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="DRIVE LINK TESTS" Style="{StaticResource SectionHeader}"/>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,10">
                                <TextBlock Text="TANK VENT VALVE" Style="{StaticResource ValueLabel}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶ Activate" Command="{Binding ActivateTankVentAsyncCommand}" Style="{StaticResource Btn.Safety}"/>
                                    <Button Content="■ Stop"     Command="{Binding StopTankVentAsyncCommand}"     Style="{StaticResource Btn.SafetyStop}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="RESONANCE FLAP" Style="{StaticResource ValueLabel}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶ Activate" Command="{Binding ActivateResonanceFlapAsyncCommand}" Style="{StaticResource Btn.Safety}"/>
                                    <Button Content="■ Stop"     Command="{Binding StopResonanceFlapAsyncCommand}"     Style="{StaticResource Btn.SafetyStop}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="FUEL INJECTORS" Style="{StaticResource ValueLabel}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶ Activate" Command="{Binding ActivateInjectorsAsyncCommand}" Style="{StaticResource Btn.Safety}"/>
                                    <Button Content="■ Stop"     Command="{Binding StopInjectorsAsyncCommand}"     Style="{StaticResource Btn.SafetyStop}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="IDLE STABILIZER VALVE" Style="{StaticResource ValueLabel}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶ Activate" Command="{Binding ActivateIsvAsyncCommand}" Style="{StaticResource Btn.Safety}"/>
                                    <Button Content="■ Stop"     Command="{Binding StopIsvAsyncCommand}"     Style="{StaticResource Btn.SafetyStop}"/>
                                </StackPanel>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- SYSTEM ADAPTATION PROGRAM -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="SYSTEM ADAPTATION PROGRAM" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource AlertBanner}">
                            <TextBlock Foreground="#F59E0B" FontSize="12" TextWrapping="Wrap"
                                       Text="Engine must be fully warm (80°C+), idling smoothly, A/C off, all loads off. SAP monitors lambda closed-loop and writes the corrected base injection pulse to non-volatile RAM."/>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶ Run SAP" Command="{Binding RunSapAsyncCommand}"
                                    Style="{StaticResource Btn.Primary}" MinWidth="110"/>
                            <Button Content="■ Stop"   Command="{Binding StopSapCommand}" MinWidth="70"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- STATUS -->
                <Border Style="{StaticResource StatusBar}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource StatusText}"
                               Foreground="{Binding HasError, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
