<UserControl x:Class="Porsche928Diagnostics.Views.PsdView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Porsche928Diagnostics.Views"
             Background="#090909" Foreground="#EEEEEE">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="{Binding IsSessionActive, Converter={x:Static views:SessionDotConverter.Instance}}"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,8">
            <StackPanel>

                <!-- ECU SESSION -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="ECU SESSION" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource AlertBanner}">
                            <TextBlock Foreground="#F59E0B" FontSize="12" TextWrapping="Wrap"
                                       Text="ℹ MODEL YEAR NOTE — The electronic PSD (Sperrdifferenzial) was standard from MY1990 only. Pre-1990 928 S4s (most 1989 cars, unless factory-optioned) have the mechanical ZF 40% limited-slip diff instead, which has no electronic module to query. No response from this ECU is expected on a pre-1990 car, not a fault."/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Initialise PSD Session" Command="{Binding ConnectEcuAsyncCommand}"
                                    Style="{StaticResource Btn.Primary}"/>
                            <TextBlock Text="{Binding EcuId}" Style="{StaticResource EcuIdText}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Read Fault Codes"  Command="{Binding ReadDtcsAsyncCommand}"/>
                            <Button Content="Clear Fault Codes" Command="{Binding ClearDtcsAsyncCommand}"
                                    Style="{StaticResource Btn.Danger}"/>
                            <Button Content="Copy"              Command="{Binding CopyDtcsCommand}"
                                    Style="{StaticResource Btn.Small}"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Dtcs}" MaxHeight="130">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}" FontFamily="Consolas" FontSize="12"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- HYDRAULIC BLEED PROCEDURE -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="HYDRAULIC BLEED PROCEDURE" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource DangerBanner}">
                            <StackPanel>
                                <TextBlock Text="⚠  SAFETY CRITICAL" Foreground="#EF4444"
                                           FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#CC8888" FontSize="12" TextWrapping="Wrap"
                                           Text="Vehicle must be on a lift with the bleeder screw accessible and the hydraulic reservoir full. Read the instruction manual before starting."/>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Button Content="▶ Start 60s Bleed" Command="{Binding StartBleedAsyncCommand}"
                                    Style="{StaticResource Btn.Safety}"/>
                            <Button Content="■ Emergency Stop"  Command="{Binding StopBleedCommand}"
                                    Style="{StaticResource Btn.SafetyStop}"/>
                        </StackPanel>
                        <!-- Countdown tile — visible only when bleed is active -->
                        <Border Style="{StaticResource ValueTile}"
                                Visibility="{Binding BleedActive, Converter={StaticResource BoolToVisConverter}}"
                                BorderBrush="#00E5A0">
                            <StackPanel>
                                <TextBlock Text="BLEED ACTIVE" Style="{StaticResource ValueLabel}" Foreground="#00E5A0"/>
                                <TextBlock Text="{Binding BleedSecondsRemaining, StringFormat={}{0}s remaining}"
                                           Style="{StaticResource ValueDisplay}" Foreground="#00E5A0"/>
                                <ProgressBar Value="{Binding BleedProgressPercent}" Maximum="1.0"
                                             Margin="0,10,0,6" Height="4"
                                             Foreground="#00E5A0" Background="#1E1E1E"/>
                                <TextBlock Foreground="#F59E0B" FontSize="12" TextWrapping="Wrap"
                                           Text="Tighten the bleeder screw before the timer reaches zero."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource StatusBar}" Margin="20,0,20,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusText}"
                       Foreground="{Binding HasError, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
        </Border>
    </Grid>
</UserControl>
