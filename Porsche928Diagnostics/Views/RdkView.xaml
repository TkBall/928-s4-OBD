<UserControl x:Class="Porsche928Diagnostics.Views.RdkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Porsche928Diagnostics.Views"
             Background="#090909" Foreground="#EEEEEE">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Background="{Binding IsSessionActive, Converter={x:Static views:SessionDotConverter.Instance}}"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,8">
            <StackPanel>

                <!-- ECU SESSION -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="ECU SESSION" Style="{StaticResource SectionHeader}"/>
                        <Border Style="{StaticResource AlertBanner}">
                            <TextBlock Foreground="#F59E0B" FontSize="12" TextWrapping="Wrap"
                                       Text="ℹ MODEL YEAR NOTE — RDK tyre-pressure monitoring was an optional extra on the 1989 928 S4 (standard from MY1990). If your car wasn't factory-fitted with this option, this ECU will not respond — that's expected, not a fault."/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Initialise RDK Session" Command="{Binding ConnectEcuAsyncCommand}"
                                    Style="{StaticResource Btn.Primary}"/>
                            <TextBlock Text="{Binding EcuId}" Style="{StaticResource EcuIdText}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Read Fault Codes"  Command="{Binding ReadDtcsAsyncCommand}"/>
                            <Button Content="Clear Fault Codes" Command="{Binding ClearDtcsAsyncCommand}"
                                    Style="{StaticResource Btn.Danger}"/>
                            <Button Content="Copy"              Command="{Binding CopyDtcsCommand}"
                                    Style="{StaticResource Btn.Small}"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Dtcs}" MaxHeight="130">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding .}" FontFamily="Consolas" FontSize="12"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- TYRE PRESSURE -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="TYRE PRESSURE SWITCH STATES" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Green = OK pressure  ·  Red = pressure loss or wheel off car"
                                   Style="{StaticResource ValueLabel}" Margin="0,0,0,12"/>
                        <Button Content="Read Pressure Sensors" Command="{Binding ReadSensorDataAsyncCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,14"/>
                        <UniformGrid Columns="2">
                            <Border Margin="0,0,6,6" Padding="20,16" CornerRadius="10" BorderThickness="1.5"
                                    BorderBrush="{Binding FlPressureOk, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="FRONT LEFT" Style="{StaticResource ValueLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding FlPressureOk}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding FlPressureOk, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,0,6" Padding="20,16" CornerRadius="10" BorderThickness="1.5"
                                    BorderBrush="{Binding FrPressureOk, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="FRONT RIGHT" Style="{StaticResource ValueLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding FrPressureOk}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding FrPressureOk, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,6,0" Padding="20,16" CornerRadius="10" BorderThickness="1.5"
                                    BorderBrush="{Binding RlPressureOk, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="REAR LEFT" Style="{StaticResource ValueLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RlPressureOk}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding RlPressureOk, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="20,16" CornerRadius="10" BorderThickness="1.5"
                                    BorderBrush="{Binding RrPressureOk, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                    Background="#181818">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="REAR RIGHT" Style="{StaticResource ValueLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RrPressureOk}"
                                               Style="{StaticResource ValueDisplaySmall}"
                                               Foreground="{Binding RrPressureOk, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <TextBlock Text="HF RECEIVER" Style="{StaticResource ValueLabel}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0"
                                     Fill="{Binding HfReceiverActive, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"/>
                            <TextBlock Text="{Binding HfReceiverActive}"
                                       Style="{StaticResource StatusText}" VerticalAlignment="Center"
                                       Foreground="{Binding HfReceiverActive, Converter={x:Static views:PresenceIsGoodConverter.Instance}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource StatusBar}" Margin="20,0,20,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusText}"
                       Foreground="{Binding HasError, Converter={x:Static views:BoolToColorConverter.Instance}}"/>
        </Border>
    </Grid>
</UserControl>
